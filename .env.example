# --- Gateway (data plane) ---
GATEWAY_ADDR=:8080
# Leave the four below empty to run gateway fully in-process (echo provider,
# stdout publisher, allow-all budget, header-based caller, no cache). Set them
# to switch to the real adapters.
KAFKA_BROKERS=
BUDGET_GRPC_TARGET=
IDENTITY_GRPC_TARGET=
REDIS_ADDR=
# Guardrails: off | redact | block. DENYLIST is comma-separated terms.
GUARDRAILS_MODE=off
GUARDRAILS_DENYLIST=

# --- Metering ---
METERING_ADDR=:8081
CLICKHOUSE_ADDR=localhost:9000
REDIS_ADDR=localhost:6379
# Empty => built-in price table; set to the rating service to use the catalog.
RATING_GRPC_TARGET=

# --- Budget (enforcement) ---
BUDGET_ADDR=:8082
BUDGET_GRPC_ADDR=:9101
BUDGET_DEFAULT_LIMIT_MICROS=5000000
# When KAFKA_BROKERS is set, budget emits an alert on every blocked request.

# --- Identity ---
IDENTITY_ADDR=:8083
IDENTITY_GRPC_ADDR=:9102
POSTGRES_DSN=postgres://marginpilot:marginpilot@localhost:5432/marginpilot?sslmode=disable

# --- Rating (price catalog) ---
RATING_ADDR=:8084
RATING_GRPC_ADDR=:9103

# --- Billing ---
BILLING_ADDR=:8085
# uses POSTGRES_DSN (revenue) + CLICKHOUSE_ADDR (COGS)
# Set STRIPE_API_KEY to switch from the mock exporter to the live Stripe adapter.
STRIPE_API_KEY=
STRIPE_METER_NAME=ai_usage

# --- Notifier ---
NOTIFIER_ADDR=:8086
# Optional: POST alerts here in addition to logging them.
NOTIFIER_WEBHOOK_URL=

# --- Analytics (Python) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
